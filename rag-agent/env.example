# EarlyCore API Key (get from https://app.earlycore.dev/settings)
EARLYCORE_API_KEY=not-set-for-local-dev

# LLM Provider (uncomment the one you use)
# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2

# Or OpenAI
# OPENAI_API_KEY=

# Or Anthropic Direct
# ANTHROPIC_API_KEY=

# Bedrock Guardrails (optional -- set after deploying guardrails.yaml)
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=

# Vector Store
VECTORSTORE_URL=postgresql://earlycore:earlycore_dev@postgres:5432/earlycore

# PostgreSQL (for pgvector)
POSTGRES_DB=earlycore
POSTGRES_USER=earlycore
POSTGRES_PASSWORD=earlycore_dev
